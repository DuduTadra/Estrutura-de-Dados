#include <stdio.h>
#include <string.h>
#include <locale.h>

#define TAM 4

int vetor[TAM];
int inicio=-1;
int fim=-1;
int aux=TAM;


void enfilar(int valor){
  if(aux==0){
       printf("\n-----------------FILA CHEIA!-----------------\n\n");
    return;
  }


  if(fim==TAM-1){
       fim=-1;
  }

   vetor[fim]=valor;
   aux--;
   printf("\n-------Vetor[%d]:%d    Vagas restantes:%d-------\n\n",fim+2,valor,aux);

   if(fim!=TAM-1){
    fim++;
  }
}



void desenfilar(){
 if(aux==TAM){
        printf("\n-----------------FILA VAZIA!-----------------!\n\n");
      return;
 }
       if(inicio==TAM-1){
        inicio=-1;
      }

      printf("\n----------Vetor[%d]:%d REMOVIDO!----------\n",inicio+2,vetor[inicio]);
      vetor[inicio]=0;
      aux++;

     if(inicio!=TAM-1){
      inicio++;
      }
}

void imprimir(){
    int i;
    printf("\n");
    for(i=-1;i<TAM-1;i++){
       printf("vetor[%d]:%d\n",i+2,vetor[i]);
    }
    printf("\n");
}


int main() {
    int opcao = -1, valor;
    while( opcao != 4)
   {
        printf("\nMenu:\n");
        printf("1. enfilar\n");
        printf("2. desenfilar\n");
        printf("3. imprimir\n");
        printf("4. Sair\n");
        printf("Escolha uma opcao: ");
        scanf("%d", &opcao);

        switch(opcao) {
            case 1:
                printf("Digite o valor a ser inserido: ");
                scanf("%d", &valor);
                enfilar(valor);
                break;
            case 2:
                desenfilar();
                break;
            case 3:
                imprimir();
                break;
            case 4:
                return(0);
            default:  
                printf("Opcao invalida!\n");
        }
    }
    return(0);
}
