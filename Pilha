    setlocale(LC_ALL,"PORTUGUESE");
    // Inserindo elementos na pilha
    push(10);
    push(20);
    push(30);

    imprimir();
    topoPilha();
        printf("\n");
    // Removendo e imprimindo elementos
    printf("Elemento removido: %d\n", pop());
    printf("Elemento removido: %d\n", pop());
    printf("\n");
    topoPilha();

}
